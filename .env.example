# OpenAI API key used to generate AI comments
# Example: OPENAI_KEY=sk-xxxx
OPENAI_KEY=

# Target Pump.fun token mint address (the token page where comments will be posted)
# Example: PUMP_MINT=9xQeWvG816bUx9EPjHmaT23yvVM5JgR9nSqmQf2K6r8U
PUMP_MINT=

# Base58 private key of your Solana wallet (used only for "existing wallet" mode)
# Important: Keep this secret and never share it.
BOT_KEY=

# Random delay range between each comment post (milliseconds)
# Smaller values = faster posting, larger values = safer/slower behavior
COMMENT_MIN_INTERVAL=1000
COMMENT_MAX_INTERVAL=4000
