############################################
# Pump.fun Trading Bot - Environment Config
# Fill this file, then rename/copy to .env
############################################

########## MUST HAVE (bot will not run without these) ##########

# Solana RPC (HTTP): used for reads, simulation, and sending transactions.
# Example provider: Helius / QuickNode / Triton.
RPC_HTTP_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Solana RPC (WebSocket): used for real-time token/program monitoring.
RPC_WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Main trading wallet private key (base58 secret key).
# Use a dedicated wallet with small balance for safety.
BOT_KEY=BASE58_SECRET_KEY

# OpenAI key for AI features (OPTIONAL).
# If empty, bot still runs but AI-based functions are disabled/skipped.
OPENAI_KEY=

########## STRATEGY (recommended to set before first run) ##########

# Minimum AI score required before auto-buy. Higher = safer/fewer trades.
AI_VALIDATION_THRESHOLD=85

# Buy amount per snipe (in SOL). Start small.
SNIPE_AMOUNT_SOL=0.01

# Max price slippage in basis points (500 = 5%).
SLIPPAGE_BPS=500

# Priority fee for faster inclusion (higher = faster/more expensive).
PRIORITY_FEE_LAMPORTS=120000

# Risk management.
STOP_LOSS_PERCENT=8
TAKE_PROFIT_PERCENT=20
TRAILING_STOP_PERCENT=6

########## OPTIONAL (can leave as default) ##########

# Pump.fun program id (keep default unless Pump changes it).
PUMP_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# Scanner polling interval in ms. Lower = faster/more RPC usage.
SCAN_INTERVAL_MS=4000

# Enable lightweight social checks in validation flow.
SOCIAL_CHECK_ENABLED=true

# Keep this many recent scanned tokens in local storage.
MAX_RECENT_TOKENS=100

# Log verbosity: info | debug | warn | error
LOG_LEVEL=info

########## ADVANCED (only if you know why) ##########

# Extra trading wallets, comma-separated base58 private keys.
# Used for multi-wallet strategies/bundling.
EXTRA_WALLET_KEYS=

# Enable bundle execution module (advanced strategy mode).
BUNDLE_ENABLED=false
